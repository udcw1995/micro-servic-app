# Database passwords
USER_DB_PASSWORD=postgres
AUTH_DB_PASSWORD=postgres

# JWT secrets — change these before deploying!
JWT_ACCESS_SECRET=your_strong_access_secret
JWT_REFRESH_SECRET=your_strong_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Initial admin user — seeded on first startup
# ADMIN_USER_ID must be identical in both services
ADMIN_USER_ID=a0eebc99-9c0b-4ef8-bb6d-6bb9bd380a11
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_admin_password
